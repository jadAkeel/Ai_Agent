{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": [],
  "model": "opencode/big-pickle",
  "agent": {
    "explore": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "temperature": 0
    },
    "plan": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "temperature": 0.1
    },
    "build": {
      "model": "opencode/big-pickle",
      "temperature": 0.1
    },
    "general": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "temperature": 0.1
    }
  },
  "provider": {
    "custom-openai-compatible": {
      "name": "custom-provider",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://YOUR_PROVIDER_BASE_URL"
      },
      "models": {
        "custom-model": {
          "name": "custom-model"
        }
      }
    },
    "custom-openai-compatible-v1": {
      "name": "custom-provider-v1",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://YOUR_PROVIDER_BASE_URL/v1"
      },
      "models": {
        "custom-model-v1": {
          "name": "custom-model-v1"
        }
      }
    }
  }
}
